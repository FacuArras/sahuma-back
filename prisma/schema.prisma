// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model ProductoPrincipal {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  nombre      String
  marca       String
  descripcion String?
  imagenPadre String
  pausado     Boolean            @default(false)
  variantes   ProductoVariante[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("productosprincipales")
}

model ProductoVariante {
  id                  String            @id @default(auto()) @map("_id") @db.ObjectId
  aroma               String
  stock               Int
  precioVenta         Float
  precioCompra        Float
  imagenUrl           String?
  pausado             Boolean           @default(false)
  productoPrincipalId String            @db.ObjectId
  productoPrincipal   ProductoPrincipal @relation(fields: [productoPrincipalId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("productosvariantes")
}

model Transaction {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  tipo        TransactionType // VENTA o GASTO
  monto       Float
  fecha       DateTime        @default(now())
  descripcion String?
  cantidad    Int?            // Cantidad de productos en la transacción

  // Relación opcional con variante de producto
  varianteId  String?         @db.ObjectId
  variante    ProductoVariante? @relation(fields: [varianteId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("transactions")
}

enum TransactionType {
  VENTA
  GASTO
  COMPRA
}

model Pedido {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  fecha         DateTime     @default(now())
  costoTotal    Float
  gananciaTotal Float
  items         ItemPedido[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("pedidos")
}

model ItemPedido {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre       String
  marca        String
  aroma        String
  precioCompra Float
  cantidad     Int
  pedidoId     String   @db.ObjectId
  pedido       Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@map("itemspedidos")
}

model Venta {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  fecha       DateTime    @default(now())
  totalVenta  Float
  metodoPago  String
  pagado      Boolean     @default(false)
  items       ItemVenta[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("ventas")
}

model ItemVenta {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  nombre       String
  marca        String
  aroma        String
  precioVenta  Float
  cantidad     Int
  varianteId   String? @db.ObjectId
  ventaId      String  @db.ObjectId
  venta        Venta   @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@map("itemsventas")
}
